APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=backend
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Gmail SMTP ────────────────────────────────────────────────────────────────
# Use an App Password (not your regular Gmail password).
# Steps:
#   1. Enable 2-Step Verification on your Google Account.
#   2. Visit https://myaccount.google.com/apppasswords
#   3. Create an app password (select "Mail" + "Other").
#   4. Copy the 16-character password into MAIL_PASSWORD below.
MAIL_MAILER=smtp
MAIL_SCHEME=
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_gmail@gmail.com
MAIL_PASSWORD=xxxx xxxx xxxx xxxx
MAIL_FROM_ADDRESS="your_gmail@gmail.com"
MAIL_FROM_NAME="${APP_NAME}"

# Email address that receives vehicle registration reminder notifications
NOTIFICATION_EMAIL=recipient@gmail.com

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Storage disk for vehicle images.
# Use 'public' for local dev (ephemeral on cloud — images lost on restart).
# Set to 'supabase' in production and configure SUPABASE_* vars below.
IMAGE_STORAGE_DISK=public

# Supabase Storage (S3-compatible) — fill these in for production
# Project Settings → Storage → S3 Connection
SUPABASE_S3_ENDPOINT=https://<project-ref>.supabase.co/storage/v1/s3
SUPABASE_S3_REGION=ap-southeast-1
SUPABASE_S3_ACCESS_KEY_ID=
SUPABASE_S3_SECRET_ACCESS_KEY=
SUPABASE_STORAGE_BUCKET=vehicles
# Public URL base: must include the bucket name at the end.
# Format: https://<project-ref>.supabase.co/storage/v1/object/public/<bucket>
SUPABASE_STORAGE_URL=https://<project-ref>.supabase.co/storage/v1/object/public/vehicles

# Windows-only: path to cacert.pem to fix SSL verification (not needed on Linux/Mac)
# Download from: https://curl.se/ca/cacert.pem
# SSL_CA_BUNDLE=C:\Users\YourName\cacert.pem

VITE_APP_NAME="${APP_NAME}"
